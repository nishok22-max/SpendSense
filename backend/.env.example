# SpendSense Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── SMTP (Email) Config ──────────────────────────────────────────────────────
# For Gmail: enable 2FA at myaccount.google.com → Security → App Passwords
# Generate a 16-char App Password and use it as SMTP_PASS (NOT your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=SpendSense <your-gmail@gmail.com>

# For Mailtrap (safe dev testing — emails don't reach real inboxes):
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=<mailtrap-username>
# SMTP_PASS=<mailtrap-password>
# SMTP_FROM=SpendSense <noreply@spendsense.dev>

# ── Frontend URL (used for email links) ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=expense_tracker
DB_USER=postgres
DB_PASS=12345
DB_PORT=5432

# ── JWT Secret ───────────────────────────────────────────────────────────────
SECRET_KEY=ai-expense-analyser-super-secret-2026
